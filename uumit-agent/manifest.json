{
  "name": "uumit-agent",
  "version": "1.1.0",
  "base_url": "https://oss.uumit.com/skills/",
  "distribution": {
    "preferred": "zip",
    "fallback": "manifest_files",
    "manifest": "manifest.json",
    "install_entrypoint": "node scripts/install.js",
    "bootstrap_files": [
      "manifest.json",
      "SKILL.md",
      "scripts/install.js"
    ],
    "install_flow": [
      "fetch manifest.json",
      "fetch scripts/install.js",
      "run node scripts/install.js"
    ],
    "update_flow": [
      "run node scripts/update_skill.js --check",
      "run node scripts/update_skill.js --update",
      "run node scripts/validate_skill.js"
    ],
    "zip": "uumit-agent.zip"
  },
  "auth_modes": [
    "short_poll",
    "push_callback_optional"
  ],
  "update": {
    "policy": "auto_check_on_cruise",
    "check": "node scripts/update_skill.js --check",
    "update": "node scripts/update_skill.js --update",
    "repair": "node scripts/update_skill.js --fill-missing",
    "verify": "node scripts/validate_skill.js",
    "preserve": [
      "memory/"
    ],
    "fallback": "download and unzip uumit-agent.zip"
  },
  "files": {
    "SKILL.md": {
      "required": true
    },
    "INTEROP.md": {
      "sha256": "cb22bb3078a2f82d829a94148d7c9f93552f4867ea9a5c5a5cd218293292d84f",
